{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "core:webview:allow-print",
    "dialog:default",
    "opener:default",
    "fs:default",
    "shell:default",
    "updater:default",
    "process:allow-restart"
  ]
}
